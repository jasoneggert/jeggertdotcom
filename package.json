{
  "name": "jeggertdotcom",
  "version": "2.0.0",
  "private": true,
  "description": "Jason Eggert portfolio site built with React and Vite.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:gh": "npm run build && bash ./scripts/deploy-gh-user-site.sh",
    "deploy:gh:push": "npm run build && bash ./scripts/deploy-gh-user-site-push.sh",
    "deploy:all": "npm run build && firebase deploy && npm run deploy:gh:push"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11"
  }
}
